


//indicando a minha onda atual, podia usar um Array mas sla, começei assim entao vai

 if (global.fase1)
{
	onda_atual = 1;

};

 if (global.fase2)
{
	onda_atual = 2;

};

 if (global.fase3)
{
	onda_atual = 3;

};

 if (global.fase4)
{
	onda_atual = 4;

};

 if (global.fase5)
{
	onda_atual = "Final";

};

  //finalizando o jogo
if (global.boss)
{
	timer += 0.07
	
}

  if (timer >= tempo)
  {      
	    timer = 0;
	    escreve_final = true; 
  }
  
  //RESETANDO LAALAALLAA 
  if (global.resetou)
 {
	   timer = 0;
	   
 }






